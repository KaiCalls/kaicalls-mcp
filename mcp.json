{
  "name": "KaiCalls",
  "schema_version": "1.0.0",
  "serverInfo": {
    "name": "KaiCalls",
    "version": "1.0.0",
    "description": "AI-powered phone answering service for businesses. Handles inbound calls, outbound campaigns, lead intake, appointment scheduling, and after-hours management."
  },
  "provider": {
    "organization": "KaiCalls",
    "url": "https://www.kaicalls.com",
    "contact_email": "connor@kaicalls.com"
  },
  "endpoints": {
    "mcp": "https://www.kaicalls.com/api/mcp",
    "documentation": "https://www.kaicalls.com/docs/api/agent-discovery"
  },
  "auth": {
    "type": "oauth2",
    "description": "OAuth 2.1 (authorization code + PKCE S256, refresh tokens, DCR). A KaiCalls API key (kc_live_*) is also accepted via Authorization Bearer or X-KaiCalls-API-Key for direct API clients and MCP gateways."
  },
