{
  "serverInfo": {
    "name": "KaiCalls",
    "version": "1.0.0",
    "description": "AI-powered phone answering service for businesses. Handles inbound calls, outbound campaigns, lead intake, appointment scheduling, and after-hours management."
  },
  "provider": {
    "organization": "KaiCalls",
    "url": "https://www.kaicalls.com",
    "contact_email": "connor@kaicalls.com"
  },
  "transport": {
    "type": "streamable-http",
    "url": "https://www.kaicalls.com/api/mcp"
  },
  "capabilities": {
    "tools": true,
    "prompts": false,
    "resources": false
  },
  "auth": {
    "type": "oauth2",
    "description": "OAuth 2.1 (authorization code + PKCE S256, refresh tokens, DCR). A KaiCalls API key (kc_live_*) is also accepted via Authorization Bearer or X-KaiCalls-API-Key for direct API clients and MCP gateways."
  },
  "tools": [
    {
      "name": "make_call",
      "title": "Make Call",
      "description": "Initiate a real outbound phone call via a KaiCalls AI agent",
      "scope": "calls:write",
      "outputSchema": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether the tool completed successfully"
          },
          "error": {
            "type": "string",
            "description": "Present when success is false"
          },
          "call": {
            "type": "object",
            "properties": {
              "id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "conversation_id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "status": {
                "type": "string"
              },
              "agent_id": {
                "type": "string"
              },
              "business_id": {
                "type": "string"
              },
              "lead_id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "to": {
                "type": "string"
              }
